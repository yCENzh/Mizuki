---
/**
 * AnalyticsScripts.astro
 * 第三方分析脚本组件 - 延迟加载优化
 *
 * 包含:
 * - Google Tag Manager (GTM)
 * - Microsoft Clarity
 *
 * 使用 requestIdleCallback 延迟加载以优化性能
 */

interface Props {
	gtmId?: string;
	clarityId?: string;
}

const {
	gtmId = "GTM-KRX3XGVH",
	clarityId = "tjr3vkhj8i",
} = Astro.props;
---

<!-- 第三方分析脚本 - 延迟加载优化 -->
<script is:inline define:vars={{ gtmId, clarityId }}>
	// 使用 requestIdleCallback 延迟加载第三方脚本
	// 标记脚本是否已加载，防止 swup 导航时重复加载
	window.analyticsLoaded = window.analyticsLoaded || false;

	function loadAnalytics() {
		if (window.analyticsLoaded) {return;}
		window.analyticsLoaded = true;

		// Google Tag Manager
		(function (w, d, s, l, i) {
			w[l] = w[l] || [];
			w[l].push({
				"gtm.start": new Date().getTime(),
				event: "gtm.js",
			});
			const f = d.getElementsByTagName(s)[0],
			j = d.createElement(s),
			dl = l != "dataLayer" ? "&l=" + l : "";
			j.async = true;
			j.src =
				"https://www.googletagmanager.com/gtm.js?id=" + i + dl;
			f.parentNode.insertBefore(j, f);
		})(window, document, "script", "dataLayer", gtmId);

		// Clarity
		(function (c, l, a, r, i, t, y) {
			c[a] =
				c[a] ||
				function () {
					(c[a].q = c[a].q || []).push(arguments);
				};
			t = l.createElement(r);
			t.async = 1;
			t.src = "https://www.clarity.ms/tag/" + i;
			y = l.getElementsByTagName(r)[0];
			y.parentNode.insertBefore(t, y);
		})(window, document, "clarity", "script", clarityId);
	}

	// 在浏览器空闲时加载，或者在 3 秒后加载
	if ("requestIdleCallback" in window) {
		requestIdleCallback(loadAnalytics, { timeout: 3000 });
	} else {
		setTimeout(loadAnalytics, 3000);
	}
</script>
