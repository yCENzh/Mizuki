---
import type { SectionTitleProps } from "./types"

const {
	title,
	count,
	icon,
	class: className = "",
} = Astro.props as SectionTitleProps
---

<h2 class={`text-2xl font-bold text-black/90 dark:text-white/90 mb-4 relative
			before:w-1 before:h-6 before:rounded-md before:bg-[var(--primary)]
            before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4 ${className}`}>
	{icon && <span class={`w-3 h-3 rounded-full ${icon} mr-3`}></span>}
	{title}
    {count !== undefined && (
	 <span class="text-lg font-normal text-black/60 dark:text-white/60 ml-2">
            ({count})
        </span>
    )}
</h2>
