---
import { SectionTitle } from "../section-title"
import type { TechStackProps } from "./types"

const {
	 techStack,
  title,
  class: className = "",
} = Astro.props as TechStackProps
---

<div class={className}>
    {title && <SectionTitle title={title} />}
    <div class="flex flex-wrap gap-2">
        {techStack.map((tech) => (
            <span class="px-3 py-1 text-sm bg-gray-600/20 text-gray-700 dark:bg-gray-800 dark:text-gray-300 rounded-full">
                {tech}
            </span>
        ))}
    </div>
</div>
