---
import WidgetLayout from "../common/WidgetLayout.astro";
import { i18n } from "../../../i18n/translation";
import I18nKey from "../../../i18n/i18nKey";

import SidebarMusicClient from "./SidebarMusicClient.svelte";
import type { SidebarMusicWidgetProps } from "./types";

const { class: className, style }: SidebarMusicWidgetProps = Astro.props;
const widgetId = `music-sidebar-widget-${Math.random().toString(36).substring(2, 9)}`;
---

<WidgetLayout
	id={widgetId}
	class={className}
	style={style}
	name={i18n(I18nKey.musicPlayer)}
>
	<SidebarMusicClient client:only="svelte" />
</WidgetLayout>
