---
import { siteConfig } from "../config";
import { UNCATEGORIZED } from "../constants/constants";
import { ProjectCard } from "../components/features/projects";
import { StatCard } from "../components/features/stats";
import {
	getAllTechStack,
	getFeaturedProjects,
	getProjectStats,
	getProjectsByCategory,
	projectsData,
} from "../data/projects";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

if (!siteConfig.featurePages.projects) {
	return Astro.redirect("/404/");
}

const stats = getProjectStats();
const featuredProjects = getFeaturedProjects();
const allTechStack = getAllTechStack();

const categories = [
	...new Set(projectsData.map((project) => project.category)),
];

const projectsByCategory = categories.reduce(
	(acc, category) => {
		acc[category] = getProjectsByCategory(category);
		return acc;
	},
	{} as Record<string, typeof projectsData>,
);

const getCategoryText = (category: string) => {
	switch (category) {
		case "web":
			return i18n(I18nKey.projectsWeb);
		case "mobile":
			return i18n(I18nKey.projectsMobile);
		case "desktop":
			return i18n(I18nKey.projectsDesktop);
		case "other":
			return i18n(I18nKey.projectsOther);
		case UNCATEGORIZED:
			return i18n(I18nKey.uncategorized);
		default:
			return category;
	}
};

const title = i18n(I18nKey.projects);
const subtitle = i18n(I18nKey.projectsSubtitle);
---

<MainGridLayout title={title} description={subtitle}>
  <script>
    import('../scripts/right-sidebar-layout.js');
    import { loadIconify } from "../utils/icon-loader";
    
    loadIconify().catch((error) => {
      console.error("Failed to load Iconify:", error);
    });
  </script>
  
  <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <div class="flex flex-col items-start justify-center mb-8">
        <h1 class="text-4xl font-bold text-black/90 dark:text-white/90 mb-2 relative
                  before:w-1 before:h-8 before:rounded-md before:bg-[var(--primary)]
                  before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4">
          {i18n(I18nKey.projects)}
        </h1>
        <p class="text-lg text-black/60 dark:text-white/60">
          {i18n(I18nKey.projectsSubtitle)}
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <StatCard 
          title={i18n(I18nKey.projectsTotal)} 
          value={stats.total.toString()} 
          color="#3B82F6" 
        />
        <StatCard 
          title={i18n(I18nKey.projectsCompleted)} 
          value={stats.byStatus.completed.toString()} 
          color="#22C55E" 
        />
        <StatCard 
          title={i18n(I18nKey.projectsInProgress)} 
          value={stats.byStatus.inProgress.toString()} 
          color="#F59E0B" 
        />
        <StatCard 
          title={i18n(I18nKey.projectsTechStack)} 
          value={allTechStack.length.toString()} 
          color="#A855F7" 
        />
      </div>

      {featuredProjects.length > 0 && (
        <div class="mb-8">
          <h2 class="text-2xl font-bold text-black/90 dark:text-white/90 mb-4 relative
                    before:w-1 before:h-6 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4">
            {i18n(I18nKey.projectsFeatured)}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featuredProjects.map((project) => (
              <ProjectCard project={project} size="medium" showImage={true} maxTechStack={3} />
            ))}
          </div>
        </div>
      )}

      <div class="space-y-8">
        {categories.map((category) => {
          const categoryProjects = projectsByCategory[category];
          if (categoryProjects.length === 0) return null;
          
          return (
            <div>
              <h2 class="text-2xl font-bold text-black/90 dark:text-white/90 mb-4 relative
                        before:w-1 before:h-6 before:rounded-md before:bg-[var(--primary)]
                        before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4">
                {getCategoryText(category)}
                <span class="text-lg font-normal text-black/60 dark:text-white/60 ml-2">
                  ({categoryProjects.length})
                </span>
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {categoryProjects.map((project) => (
                  <ProjectCard project={project} size="medium" showImage={true} maxTechStack={3} />
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <div class="mt-12 pt-8 border-t border-black/10 dark:border-white/10">
        <h2 class="text-2xl font-bold text-black/90 dark:text-white/90 mb-4">
          {i18n(I18nKey.projectsTechStack)}
        </h2>
        <div class="flex flex-wrap gap-2">
          {allTechStack.map((tech) => (
            <span class="px-3 py-1 text-sm bg-gray-600/20 text-gray-700 dark:bg-gray-800 dark:text-gray-300 rounded-full">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</MainGridLayout>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
